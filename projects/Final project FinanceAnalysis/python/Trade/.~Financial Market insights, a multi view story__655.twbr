      <aliases enabled='yes' />
      <column datatype='real' default-format='p0.00%' name='[Calculation1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(ZN(SUM([Price])) - LOOKUP(ZN(SUM([Price])), -1)) / ABS(LOOKUP(ZN(SUM([Price])), -1))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Moving Average Forecast' datatype='real' name='[Calculation_4334503593626701827]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SCRIPT_REAL(&quot;&#10;import pandas as pd&#10;# Convert the incoming data into a pandas Series&#10;data = pd.Series(_arg1)&#10;# Compute the 5-period moving average&#10;forecast = data.rolling(window=5).mean()&#10;# Return the forecast as a list to Tableau&#10;return forecast.tolist()&#10;&quot;, SUM([Price]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='dimension filter' datatype='boolean' name='[Calculation_4334503593676075015]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// Keeps only the chosen day and the day before it&#10;[Date] &gt;= DATEADD(&apos;day&apos;, -1, [Parameters].[Parameter 1]) &#10;AND [Date] &lt;= [Parameters].[Parameter 1]' />
      </column>
      <column caption='Filter to 2 Days' datatype='boolean' name='[Calculation_4334503593677053960]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Date] &gt;= DATEADD(&apos;day&apos;, -1, [Parameters].[Parameter 1]) &#10;AND&#10;[Date] &lt;= [Parameters].[Parameter 1]' />
      </column>
