      <column caption='High Fatalities &amp; S&amp;P Drop' datatype='string' name='[Calculation_6027927417452208132]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF&#10;    SUM([fatalities]) &gt; 50&#10;    AND&#10;    SUM([S&amp;P500]) &lt; LOOKUP(SUM([S&amp;P500]), -1)&#10;THEN&#10;    &quot;Red Dot&quot;&#10;ELSE&#10;    &quot;No Dot&quot;&#10;END'>
